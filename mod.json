{
    "geode": "5.6.1",
    "gd": {
        "android": "2.2081",
        "win": "2.2081",
        "mac": "2.2081",
        "ios": "2.2081"
    },
    "version": "v1.0.0",
    "id": "darkping.integrated_turklist",
    "name": "Integrated Turklist",
    "developers": ["darkping", "hiimjasmine00"],
    "description": "Integration for the Turkish Demonlist.",
    "resources": {
        "sprites": [
            "resources/*.png"
        ]
    },
    "settings": {
        "enable-rank": {
            "name": "Enable Demon Ranking Text",
            "description": "Whether or not to display the demon ranking text.",
            "type": "bool",
            "default": true
        },
        "white-rank": {
            "name": "White Demon Ranking Text",
            "description": "Whether or not to display the demon ranking text in white.",
            "type": "bool",
            "enable-if": "enable-rank",
            "default": false
        }
    },
    "dependencies": {
        "geode.node-ids": ">=v1.9.0"
    },
    "links": {
        "community": "https://discord.gg/xmSDbhCF",
        "source": "https://github.com/darkping-dev11/IntegratedTurklist",
        "homepage": "https://turklist.tr"
    },
    "tags": [
        "content",
        "enhancement",
        "interface",
        "online",
        "utility"
    ]
}
